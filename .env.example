# Servidor ZAccess (API + Socket.IO). Deixe vazio para rodar só o painel local.
# Ex.: http://192.168.1.100:3000  ou  http://localhost:3000
ZACCESS_SERVER_URL=

# Número de série do dispositivo cadastrado no ZAccess (obrigatório se ZACCESS_SERVER_URL estiver definido)
ZACCESS_DEVICE_SERIAL=

# Token do dispositivo (opcional; se definido no cadastro do dispositivo no ZAccess, informe aqui)
# ZACCESS_DEVICE_TOKEN=

# Porta do painel web local (padrão: 3080)
# PORT=3080

# Chave de sessão Flask (opcional; se vazio usa valor padrão em app.py)
# Gere algo único em produção (ex.: openssl rand -hex 32)
# ZAPY_SECRET_KEY=troque-esta-chave


# Pulso de reles
PULSE_RELE_1=
PULSE_RELE_2=
PULSE_RELE_3=
PULSE_RELE_4=1